# Google AdSense Configuration
# This is your Google AdSense Publisher ID
# Keep this in your public code (it's meant to be public)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-6247519976767626

# Cron Job Security
# Generate a strong random secret for the automated blog generation endpoint
# This prevents unauthorized calls to the /api/cron/generate-blog endpoint
# Generate with: openssl rand -hex 32
# Set this in your Vercel project environment variables
CRON_SECRET=your_secure_random_secret_here
